# CMake
/build/
/out/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
Testing/

# godot-cpp generated bindings and build artifacts
third_party/godot-cpp/bin/
third_party/godot-cpp/gen/
third_party/godot-cpp/build/

# Compiled extension output (regenerated by the build, includes the lore.dll
# runtime dependency copied in as a post-build step)
test_project/addons/godot-lore-plugin/bin/*.dll
test_project/addons/godot-lore-plugin/bin/*.pdb
test_project/addons/godot-lore-plugin/bin/*.lib
test_project/addons/godot-lore-plugin/bin/*.exp

# Godot editor artifacts
test_project/.godot/
*.translation

# Local Lore repository fixtures used for manual EditorVCSInterface testing
# (Godot always passes the project root to _initialize, so a fixture repo
# for interactive testing has to live inside test_project/, not scratchpad).
# Never commit repository state, only the plugin source that reads it.
**/.lore/
test_project/committed_file.txt
test_project/staged_file.txt
test_project/new_untracked.txt

# Editor / OS cruft
.vs/
.vscode/
*.user
